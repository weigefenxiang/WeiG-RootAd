#!/sbin/sh

umask 022
ui_print() { echo "$1"; }
require_new_magisk() {
  ui_print "Please install this module with a current Magisk app."
  exit 1
}

OUTFD=$2
ZIPFILE=$3
mount /data 2>/dev/null
[ -f /data/adb/magisk/util_functions.sh ] || require_new_magisk
. /data/adb/magisk/util_functions.sh
[ "$MAGISK_VER_CODE" -lt 26000 ] && require_new_magisk
install_module
exit 0

